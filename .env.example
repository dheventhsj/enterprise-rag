# Application
APP_NAME=enterprise-rag
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://rag:ragpassword@localhost:5432/enterprise_rag
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=enterprise_rag_chunks
QDRANT_API_KEY=

# Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=32

# LLM (set one provider)
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# RAG tuning
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5
MAX_CONTEXT_TOKENS=4096

# Upload
MAX_UPLOAD_SIZE_MB=25
ALLOWED_EXTENSIONS=["pdf","docx","txt"]
UPLOAD_DIR=uploads

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Monitoring
METRICS_ENABLED=true
